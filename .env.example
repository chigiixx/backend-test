# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env

# === App ===
APP_NAME=Developer Landing Backend
APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# === CORS ===
# Список разрешённых origin через запятую, либо * для всех (демо/разработка)
CORS_ORIGINS=*

# === Хранение данных (файловое: логи, JSON) ===
DATA_DIR=data

# === AI ===
# openai | none (none — всегда использовать fallback-анализ без обращения к AI)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=10

# === Email ===
# mock — письма не отправляются, сохраняются в data/emails/*.txt и пишутся в лог
# smtp — реальная отправка через smtplib (нужно заполнить SMTP_* ниже)
EMAIL_BACKEND=mock
OWNER_EMAIL=owner@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# === Rate limiting ===
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=600
